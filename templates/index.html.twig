function openEditModal(url) {
  var modal = document.getElementById('editModal');
  var content = document.getElementById('editModalContent');
  content.innerHTML = '<div class="p-4 text-center">Loading...</div>';
  modal.style.display = 'flex';

  fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
    .then(function(r) { return r.text(); })
    .then(function(html) {
      content.innerHTML = html;
      bindEditForm();
    });
}

function bindEditForm() {
  var content = document.getElementById('editModalContent');
  var form = content.querySelector('.edit-modal-form');
  if (!form) return;

  form.addEventListener('submit', function(e) {
    e.preventDefault();
    var formData = new FormData(form);
    fetch(form.action, {
      method: 'POST',
      headers: { 'X-Requested-With': 'XMLHttpRequest' },
      body: formData
    }).then(function(r) {
      if (r.headers.get('content-type') && r.headers.get('content-type').indexOf('application/json') !== -1) {
        return r.json().then(function(data) {
          if (data.success) {
            closeEditModal();
            location.reload();
          }
        });
      } else {
        return r.text().then(function(html) {
          content.innerHTML = html;
          bindEditForm();
        });
      }
    });
  });
}

function closeEditModal() {
  document.getElementById('editModal').style.display = 'none';
  document.getElementById('editModalContent').innerHTML = '';
}

function closeCategoryModal() {
  document.getElementById('categoryModal').style.display = 'none';
  // Reset to the original header for next add
  document.getElementById('categoryModalHeader').innerHTML = '<div><h4 class="fw-bold mb-1">Create New Category</h4><p class="text-muted small mb-0">Add a new product category</p></div><button type="button" class="btn-close" aria-label="Close" onclick="closeCategoryModal()"></button>';
}

function openEditCategoryModal(categoryId) {
  var modal = document.getElementById('categoryEditModal');
  var content = document.getElementById('categoryEditModalContent');
  content.innerHTML = '<div class="p-4 text-center">Loading...</div>';
  modal.style.display = 'flex';

  fetch('{{ path("category_edit", {"id": "__ID__"}) }}'.replace('__ID__', categoryId), { 
    headers: { 'X-Requested-With': 'XMLHttpRequest' } 
  })
    .then(function(r) { return r.text(); })
    .then(function(html) {
      content.innerHTML = html;
      bindCategoryEditForm();
    })
    .catch(function(e) {
      content.innerHTML = '<div class="p-4"><div class="alert alert-danger">Error loading form. Please try again.</div><button type="button" class="btn btn-secondary" onclick="closeCategoryEditModal()">Close</button></div>';
    });
}

function closeCategoryEditModal() {
  document.getElementById('categoryEditModal').style.display = 'none';
  document.getElementById('categoryEditModalContent').innerHTML = '';
}

function bindCategoryEditForm() {
  var content = document.getElementById('categoryEditModalContent');
  var form = content.querySelector('.category-edit-form');
  if (!form) return;

  form.addEventListener('submit', function(e) {
    e.preventDefault();
    var formData = new FormData(form);
    fetch(form.action, {
      method: 'POST',
      headers: { 'X-Requested-With': 'XMLHttpRequest' },
      body: formData
    }).then(function(r) {
      if (r.ok) {
        closeCategoryEditModal();
        location.reload();
      } else {
        return r.text().then(function(html) {
          content.innerHTML = html;
          bindCategoryEditForm();
        });
      }
    });
  });
}

// ============================================
// CART AND PRODUCT FILTERING FOR NON-ADMIN USERS
// ============================================
var cart = [];

function updateCartDisplay() {
  var total = cart.reduce(function(sum, item) { return sum + item.price * item.quantity; }, 0);
  var count = cart.reduce(function(sum, item) { return sum + item.quantity; }, 0);
  
  var badge = document.getElementById('cart-count');
  if (badge) badge.textContent = count;

  var headerTotal = document.getElementById('cart-total-header');
  if (headerTotal) headerTotal.textContent = '$' + total.toFixed(2);

  var offcanvasTotal = document.getElementById('cart-total-offcanvas');
  if (offcanvasTotal) offcanvasTotal.textContent = '$' + total.toFixed(2);

  var cartList = document.getElementById('cart-items-list');
  if (cartList) {
    cartList.innerHTML = '';
    cart.forEach(function(item) {
      var li = document.createElement('li');
      li.className = 'list-group-item';
      li.innerHTML = `
        <div class="d-flex align-items-center gap-2 mb-2">
            <img src="${item.image}" style="width: 40px; height: 40px; object-fit: cover; border-radius: 4px;" alt="">
            <div class="flex-grow-1">
                <h6 class="my-0 small fw-bold">${item.name}</h6>
                <small class="text-body-secondary">$${item.price.toFixed(2)}</small>
            </div>
            <button type="button" class="btn-close" style="font-size: 0.7rem" onclick="removeFromCart(${item.id})"></button>
        </div>
        <div class="d-flex justify-content-between align-items-center">
            <div class="btn-group" role="group">
                <button type="button" class="btn btn-sm btn-outline-secondary py-0" onclick="updateQuantity(${item.id}, -1)">-</button>
                <span class="btn btn-sm btn-light py-0" disabled>${item.quantity}</span>
                <button type="button" class="btn btn-sm btn-outline-secondary py-0" onclick="updateQuantity(${item.id}, 1)">+</button>
            </div>
            <span class="text-body-secondary small fw-bold">$${(item.price * item.quantity).toFixed(2)}</span>
        </div>`;
      cartList.appendChild(li);
    });
    var totalLi = document.createElement('li');
    totalLi.className = 'list-group-item d-flex justify-content-between';
    totalLi.innerHTML = '<span>Total (USD)</span><strong>$' + total.toFixed(2) + '</strong>';
    cartList.appendChild(totalLi);
  }
}
function showCartToast(name) {
    const toast = document.getElementById('cartToast');
    const msg = document.getElementById('toastMessage');
    
    if (toast && msg) {
        msg.innerText = name + ' was added successfully.';
        
        // Reset display to trigger animation
        toast.style.display = 'none';
        void toast.offsetWidth; // Trigger reflow
        toast.style.display = 'block';
        
        // Auto-hide after 4 seconds
        setTimeout(function() {
            toast.style.display = 'none';
        }, 4000);
    }
}
function removeFromCart(productId) {
  cart = cart.filter(function(item) { return item.id !== productId; });
  updateCartDisplay();
}

function updateQuantity(productId, change) {
  var item = cart.find(function(i) { return i.id === productId; });
  if (item) {
    item.quantity += change;
    if (item.quantity <= 0) {
      removeFromCart(productId);
    } else {
      updateCartDisplay();
    }
  }
}

function showNotification(message) {
  var notification = document.createElement('div');
  notification.className = 'alert alert-success position-fixed bottom-0 end-0 m-3';
  notification.style.zIndex = '9999';
  notification.innerHTML = '<small>' + message + '</small>';
  document.body.appendChild(notification);
  setTimeout(function() {
    notification.remove();
  }, 2500);
}

function openCheckoutModal() {
    if (cart.length === 0) {
        alert('Your cart is empty!');
        return;
    }

    // FIX: Force-close the side cart so it doesn't block inputs
    const cartOffcanvasEl = document.getElementById('offcanvasCart');
    if (cartOffcanvasEl) {
        const instance = bootstrap.Offcanvas.getInstance(cartOffcanvasEl) || new bootstrap.Offcanvas(cartOffcanvasEl);
        instance.hide();
    }

    // Rebuild Summary...
    const checkoutList = document.getElementById('checkout-items-list');
    checkoutList.innerHTML = '';
    let total = 0;
    cart.forEach(item => {
        total += item.price * item.quantity;
        const li = document.createElement('li');
        li.className = 'list-group-item d-flex justify-content-between border-0 px-0 small';
        li.innerHTML = `
          <div class="d-flex align-items-center">
              <img src="${item.image}" style="width: 30px; height: 30px; object-fit: cover; margin-right: 10px;">
              <span>${item.name} x${item.quantity}</span>
          </div>
          <strong>$${(item.price * item.quantity).toFixed(2)}</strong>`;
      checkoutList.appendChild(li);
    });
    document.getElementById('checkout-total').innerText = '$' + total.toFixed(2);

    // Show Checkout Modal
    document.getElementById('checkoutModal').style.display = 'flex';
    console.log("Checkout Modal opened.");

    setTimeout(() => { document.getElementById('card-name').focus(); }, 400);
}

function processOrder() {
    const nameInput = document.getElementById('card-name').value;
    const cardInput = document.getElementById('card-number').value;
    const totalValue = document.getElementById('checkout-total').innerText;

    if (nameInput.trim() === "" || (selectedMethod !== 'PayPal' && cardInput.length < 16)) {
        showError("⚠️ Please check your payment details.");
        return;
    }

    // Populate Receipt data
    try {
        document.getElementById('display-card-name').innerText = nameInput;
        document.getElementById('display-total-paid').innerText = document.getElementById('checkout-total').innerText;
        document.getElementById('display-date').innerText = new Date().toLocaleString();
        
        const cardNum = document.getElementById('card-number').value;
        document.getElementById('display-card-number').innerText = "**** **** **** " + cardNum.slice(-4);
    } catch (e) {
        console.error("Error filling receipt:", e);
    }
    // 3. SWITCH VISIBILITY (The critical part)
    // Hide checkout
    document.getElementById('checkoutModal').style.display = 'none';
    
    // Show success with forced inline styles to ensure it's on top
    const successMdl = document.getElementById('successOrderModal');
    successMdl.style.cssText = "display: flex !important; position: fixed !important; z-index: 9999 !important; align-items: center; justify-content: center; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.8);";

    // 4. RESET THE DATA IMMEDIATELY
    // This ensures that even if they click 'Cancel' or 'Back', the cart is gone
    cart = []; 
    if (typeof updateCartDisplay === "function") {
        updateCartDisplay();
    }

    console.log("Success Modal forced to flex and cart cleared.");
    
}




function showError(message) {
    const errorBox = document.getElementById('checkout-error-msg');
    errorBox.innerText = message;
    errorBox.style.display = 'block';
    
    // Optional: Shake the modal
    const win = document.querySelector('.modal-window');
    win.style.transform = 'translateX(10px)';
    setTimeout(() => win.style.transform = 'translateX(-10px)', 100);
    setTimeout(() => win.style.transform = 'translateX(0)', 200);
}
function closeCheckoutModal() {
  document.getElementById('checkoutModal').style.display = 'none';
}

function placeOrder() {
  if (cart.length === 0) {
    showNotification('Cart is empty!');
    return;
  }
  
  var total = cart.reduce(function(sum, item) { return sum + item.price * item.quantity; }, 0);
  alert('Order placed successfully!\n\nTotal: $' + total.toFixed(2) + '\n\nThank you for your purchase!');
  
  closeCheckoutModal();
  cart = [];
  updateCartDisplay();
}

function filterProducts() {
  var categoryVal = (document.getElementById('product-category-filter') || {}).value || '';
  var searchVal = (document.getElementById('product-filter-input') || document.getElementById('header-search-input') || {}).value || '';
  searchVal = searchVal.trim().toLowerCase();

  document.querySelectorAll('.product-card').forEach(function(card) {
    var name = card.getAttribute('data-product-name') || '';
    var cat  = card.getAttribute('data-category-name') || '';
    var matchCat    = !categoryVal || cat === categoryVal.toLowerCase();
    var matchSearch = !searchVal  || name.indexOf(searchVal) !== -1 || cat.indexOf(searchVal) !== -1;
    card.style.display = (matchCat && matchSearch) ? '' : 'none';
  });

  document.querySelectorAll('.category-card').forEach(function(card) {
    var cat = card.getAttribute('data-category-name') || '';
    card.style.display = (!searchVal || cat.indexOf(searchVal) !== -1) ? '' : 'none';
  });
}

// Initialize on page load
document.addEventListener('DOMContentLoaded', function() {
  updateCartDisplay();

  // All filter inputs share the same filterProducts function
  ['product-category-filter', 'category-filter', 'header-category-filter'].forEach(function(id) {
    var el = document.getElementById(id);
    if (el) {
      el.addEventListener('change', function() {
        // Sync all category dropdowns to same value
        ['product-category-filter', 'category-filter', 'header-category-filter'].forEach(function(syncId) {
          var s = document.getElementById(syncId);
          if (s) s.value = el.value;
        });
        filterProducts();
      });
    }
  });

  ['product-filter-input', 'header-search-input'].forEach(function(id) {
    var el = document.getElementById(id);
    if (el) el.addEventListener('input', filterProducts);
  });
});
</script>

