<script>
function showError(message) {
    const errorBox = document.getElementById('checkout-error-msg');
    const modalWindow = document.querySelector('#checkoutModal .modal-window');
    // Add this inside your <script> tag
    document.addEventListener('DOMContentLoaded', function() {
        const cardInput = document.getElementById('card-number');

        if (cardInput) {
            cardInput.addEventListener('input', function (e) {
                // 1. Remove all non-digits
                let value = e.target.value.replace(/\D/g, '');
                
                // 2. Add a space every 4 digits using Regex
                let formattedValue = value.match(/.{1,4}/g)?.join(' ') || '';
                
                // 3. Limit to 19 characters (16 digits + 3 spaces)
                e.target.value = formattedValue.substring(0, 19);
            });
        }
    });
    if (errorBox) {
        errorBox.innerText = message;
        errorBox.style.display = 'block';
        
        // Auto-hide error when user starts typing again
        const inputs = document.querySelectorAll('#checkoutModal input');
        inputs.forEach(input => {
            input.addEventListener('input', () => {
                errorBox.style.display = 'none';
            }, { once: true });
        });
    }

    // Trigger the shake animation
    if (modalWindow) {
        modalWindow.classList.add('shake');
        setTimeout(() => {
            modalWindow.classList.remove('shake');
        }, 400);
    }
}



let selectedMethod = "Visa"; 

function selectCardType(method) {
    selectedMethod = method;
    
    // 1. Reset all options to default (gray border, white bg)
    document.querySelectorAll('.card-type-option').forEach(el => {
        el.style.backgroundColor = "#ffffff";
        el.style.borderColor = "#dee2e6";
        el.style.color = "#6c757d"; // Muted text
        el.classList.add('text-muted');
    });

    // 2. Highlight the selected one (Blue border, Light blue background)
    const activeEl = document.getElementById('type-' + method.toLowerCase());
    activeEl.style.backgroundColor = "#e7f1ff"; // Light blue tint
    activeEl.style.borderColor = "#0d6efd";     // Bootstrap primary blue
    activeEl.style.color = "#0d6efd";           // Blue text
    activeEl.classList.remove('text-muted');
}


function closeCheckoutModal() {
    document.getElementById('checkoutModal').style.display = 'none';
}


function clearCartAndFinish() {
    // This refreshes the page to reset the cart state
    window.location.reload(); 
}
