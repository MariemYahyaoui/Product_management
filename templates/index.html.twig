    <div class="preloader-wrapper">
      <div class="preloader">
      </div>
    </div>

    {# Dashboard Navigation - Show appropriate message based on role #}
    {% if app.user and 'ROLE_ADMIN' in app.user.roles %}
    <div class="alert alert-warning d-flex justify-content-between align-items-center mb-0" role="alert">
      <span><strong>Admin Dashboard</strong> - Full management access</span>
      <a href="{{ path('app_client_dashboard') }}" class="btn btn-sm btn-info">Go to Client Dashboard</a>
    </div>
    {% elseif app.user %}
    <div class="alert alert-info d-flex justify-content-between align-items-center mb-0" role="alert">
      <span><strong>Shopping Dashboard</strong> - Browse & add products to cart</span>
      {% if 'ROLE_ADMIN' not in app.user.roles %}
      <a href="{{ path('app_index') }}" class="btn btn-sm btn-primary">Refresh</a>
      {% endif %}
    </div>
    {% endif %}

    {# Cart Offcanvas - Only for logged-in non-admins #}
    {% if app.user and 'ROLE_ADMIN' not in app.user.roles %}
    <div class="offcanvas offcanvas-end" data-bs-scroll="true" tabindex="-1" id="offcanvasCart" aria-labelledby="My Cart">
      <div class="offcanvas-header justify-content-center">
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
      </div>
      <div class="offcanvas-body">
        <div class="order-md-last">
          <h4 class="d-flex justify-content-between align-items-center mb-3">
            <span class="text-primary">Your cart</span>
            <span class="badge bg-primary rounded-pill" id="cart-count">0</span>
          </h4>
          <ul class="list-group mb-3" id="cart-items-list">
            <li class="list-group-item d-flex justify-content-between">
              <span>Total (USD)</span>
              <strong id="cart-total-offcanvas">$0.00</strong>
            </li>
          </ul>
          <button class="w-100 btn btn-primary btn-lg" type="button" onclick="openCheckoutModal()">Continue to checkout</button>
        </div>
      </div>
    </div>
    {% elseif app.user and 'ROLE_ADMIN' in app.user.roles %}
    <div class="offcanvas offcanvas-end" data-bs-scroll="true" tabindex="-1" id="offcanvasCart" aria-labelledby="My Cart">
      <div class="offcanvas-header justify-content-center">
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
      </div>
      <div class="offcanvas-body">
        <div class="order-md-last">
          <h4 class="d-flex justify-content-between align-items-center mb-3">
            <span class="text-primary">Your cart</span>
            <span class="badge bg-primary rounded-pill">3</span>
          </h4>
          <ul class="list-group mb-3">
            <li class="list-group-item d-flex justify-content-between lh-sm">
              <div>
                <h6 class="my-0">Growers cider</h6>
                <small class="text-body-secondary">Brief description</small>
              </div>
              <span class="text-body-secondary">$12</span>
            </li>
            <li class="list-group-item d-flex justify-content-between lh-sm">
              <div>
                <h6 class="my-0">Fresh grapes</h6>
                <small class="text-body-secondary">Brief description</small>
              </div>
              <span class="text-body-secondary">$8</span>
            </li>
            <li class="list-group-item d-flex justify-content-between lh-sm">
              <div>
                <h6 class="my-0">Heinz tomato ketchup</h6>
                <small class="text-body-secondary">Brief description</small>
              </div>
              <span class="text-body-secondary">$5</span>
            </li>
            <li class="list-group-item d-flex justify-content-between">
              <span>Total (USD)</span>
              <strong>$20</strong>
            </li>
          </ul>
  
          <button class="w-100 btn btn-primary btn-lg" type="submit">Continue to checkout</button>
        </div>
      </div>
    </div>
    {% endif %}
    
    <div class="offcanvas offcanvas-end" data-bs-scroll="true" tabindex="-1" id="offcanvasSearch" aria-labelledby="Search">
      <div class="offcanvas-header justify-content-center">
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
      </div>
      <div class="offcanvas-body">
        <div class="order-md-last">
          <h4 class="d-flex justify-content-between align-items-center mb-3">
            <span class="text-primary">Search</span>
          </h4>
          <div class="d-flex mt-3 gap-0">
            <input class="form-control rounded-start rounded-0 bg-light" type="text" id="offcanvas-search-input" placeholder="What are you looking for?">
            <button class="btn btn-dark rounded-end rounded-0" type="button" id="offcanvas-search-btn">Search</button>
          </div>
        </div>
      </div>
    </div>
      {# Checkout Modal #}
<div class="modal-overlay" id="checkoutModal" style="display:none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 2000; align-items: center; justify-content: center;">
    <div class="modal-window" style="background: white; border-radius: 12px; width: 100%; max-width: 500px; overflow: hidden; box-shadow: 0 10px 25px rgba(0,0,0,0.2);">
        <div class="p-4 border-bottom d-flex justify-content-between align-items-center">
            <h4 class="fw-bold mb-0">Order Confirmation</h4>
            <button type="button" class="btn-close" onclick="closeCheckoutModal()"></button>
        </div>
        <div class="p-4">
            <h5 class="mb-3">Order Summary</h5>
            <div id="checkout-error-msg" class="alert alert-danger" style="display:none; font-size: 0.85rem; padding: 10px; margin-bottom: 15px;"></div>            

            <ul class="list-group mb-3" id="checkout-items-list" style="max-height: 150px; overflow-y: auto;"></ul>
            <div class="d-flex justify-content-between p-2 bg-light rounded border mb-4">
                <span class="fw-bold">Total:</span>
                <span class="fw-bold text-primary" id="checkout-total">$0.00</span>
            </div>
            <h6 class="fw-bold mb-3 small text-uppercase">Payment Method</h6>
            <div class="d-flex gap-2 mb-3">
                <div class="card-type-option border rounded p-2 text-center flex-fill selected" id="type-visa" onclick="selectCardType('Visa')" style="cursor:pointer; border: 2px solid #0d6efd; background-color: #e7f1ff;">
                    <small class="fw-bold">VISA</small>
                </div>
                <div class="card-type-option border rounded p-2 text-center flex-fill text-muted" id="type-mastercard" onclick="selectCardType('Mastercard')" style="cursor:pointer;">
                    <small class="fw-bold">Mastercard</small>
                </div>
                <div class="card-type-option border rounded p-2 text-center flex-fill text-muted" id="type-paypal" onclick="selectCardType('PayPal')" style="cursor:pointer;">
                    <small class="fw-bold">PayPal</small>
                </div>
            </div>
            
            <div class="mb-2">
                <label class="small fw-bold">Cardholder Name</label>
                <input type="text" id="card-name"  class="form-control" placeholder="Full Name" style="z-index: 2001;">
            </div>
            <div class="mb-2">
                <label class="small fw-bold">Card Details</label>
                <input type="text" id="card-number"  class="form-control" placeholder="16 Digit Card Number" maxlength="16" style="z-index: 2001;">
            </div>

            <div class="d-flex gap-2 justify-content-end mt-4">
                <button type="button" class="btn btn-secondary" onclick="closeCheckoutModal()">Cancel</button>
                <button type="button" class="btn btn-success px-4" onclick="processOrder()">Place Order</button>
            </div>
        </div>
    </div>
</div>



<div id="successOrderModal" class="modal-overlay" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.7); z-index: 3000; align-items: center; justify-content: center;">
    <div class="modal-window text-center p-5" style="background: white; border-radius: 12px; width: 100%; max-width: 500px; box-shadow: 0 10px 25px rgba(0,0,0,0.2);">
        <div class="mb-4">
            <div class="bg-success-subtle rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 60px; height: 60px; background-color: #d1e7dd;">
                <svg width="30" height="30" style="color: #198754;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </div>
        </div>
        <h3 class="fw-bold mb-4">Order Successful!</h3>
        <div id="printable-receipt" class="text-start border p-3 rounded bg-light mb-4">
            <div class="d-flex justify-content-between"><span>Customer:</span><span id="display-card-name" class="fw-bold"></span></div>
            <div class="d-flex justify-content-between"><span>Payment:</span><span id="display-card-number" class="fw-bold"></span></div>
            <div class="d-flex justify-content-between"><span>Date:</span><span id="display-date" class="fw-bold"></span></div>
            <hr>
            <div class="d-flex justify-content-between"><strong>Total Paid:</strong><strong id="display-total-paid" class="text-primary"></strong></div>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-dark w-50" onclick="window.print()">Print</button>
            <button class="btn btn-warning w-50" onclick="location.reload()">Done</button>
        </div>
    </div>
</div>
    <header>
      <div class="container-fluid">
        <div class="row py-3 border-bottom">
          
          <div class="col-sm-4 col-lg-3 text-center text-sm-start">
            <div class="main-logo">
              <a href="{{ path('app_index') }}">
                <img src="{{ asset('images/logo.png') }}" alt="logo" class="img-fluid">
              </a>
            </div>
          </div>
          
          <div class="col-sm-6 offset-sm-2 offset-md-0 col-lg-5 d-none d-lg-block">
            <div class="search-bar row bg-light p-2 my-2 rounded-4">
              <div class="col-md-4 d-none d-md-block">
                  <select class="form-select border-0 bg-transparent" id="header-category-filter">
                    <option value="">All Categories</option>
                    {% if categories is defined %}
                      {% for category in categories %}
                        <option value="{{ category.categoryName|lower }}">{{ category.categoryName }}</option>
                      {% endfor %}
                    {% endif %}
                  </select>
              </div>
              <div class="col-11 col-md-7">
                <input type="text" id="header-search-input" class="form-control border-0 bg-transparent" placeholder="Search for more products" />
              </div>
              <div class="col-1">
                <button type="button" class="btn btn-link p-0 d-flex align-items-center justify-content-center" onclick="filterProducts()" title="Search">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><path fill="currentColor" d="M21.71 20.29L18 16.61A9 9 0 1 0 16.61 18l3.68 3.68a1 1 0 0 0 1.42 0a1 1 0 0 0 0-1.39ZM11 18a7 7 0 1 1 7-7a7 7 0 0 1-7 7Z"/></svg>
                </button>
              </div>
