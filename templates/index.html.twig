<script>


// Updated addToCart with Pop-out
function addToCart() {
    // We use 'arguments' to bypass variable name errors
    var pId    = arguments[0];
    var pName  = arguments[1];
    var pPrice = arguments[2];
    var pImg   = arguments[3];

    console.log("Adding to cart:", pName, "at price:", pPrice);

    var existing = cart.find(function(item) { 
        return item.id === pId; 
    });

    if (existing) {
        existing.quantity += 1;
    } else {
        cart.push({ 
            id: pId, 
            name: pName, 
            price: parseFloat(pPrice), 
            image: pImg, 
            quantity: 1 
        });
    }

    if (typeof updateCartDisplay === "function") {
        updateCartDisplay();
    }
    
    showCartToast(pName);
}
function filterProducts() {
  var categoryVal = (document.getElementById('product-category-filter') || {}).value || '';
  var searchVal = (document.getElementById('product-filter-input') || document.getElementById('header-search-input') || {}).value || '';
  searchVal = searchVal.trim().toLowerCase();

  document.querySelectorAll('.product-card').forEach(function(card) {
    var name = card.getAttribute('data-product-name') || '';
    var cat  = card.getAttribute('data-category-name') || '';
    var matchCat    = !categoryVal || cat === categoryVal.toLowerCase();
    var matchSearch = !searchVal  || name.indexOf(searchVal) !== -1 || cat.indexOf(searchVal) !== -1;
    card.style.display = (matchCat && matchSearch) ? '' : 'none';
  });

  document.querySelectorAll('.category-card').forEach(function(card) {
    var cat = card.getAttribute('data-category-name') || '';
    card.style.display = (!searchVal || cat.indexOf(searchVal) !== -1) ? '' : 'none';
  });
}

