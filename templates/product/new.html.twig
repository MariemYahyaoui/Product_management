{% extends 'base.html.twig' %}

{% block title %}Create Product{% endblock %}

{% block body %}
    <div class="container py-5">
        <div class="row justify-content-center mb-5">
            <div class="col-lg-8 col-md-10">
                <div class="mb-4">
                    <h1 class="display-6 fw-bold text-dark mb-2">Create New Product</h1>
                    <p class="text-muted fs-6">Add a new product to your catalog</p>
                </div>

                <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                    <div class="card-body p-5">
                        {% include 'product/_form.html.twig' with {'form': form, 'button_label': 'Create Product'} %}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
