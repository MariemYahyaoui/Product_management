{% block javascripts %}
<script src="{{ asset('js/jquery-1.11.0.min.js') }}"></script>
<script src="https://cdn.jsdelivr.net/npm/swiper@9/swiper-bundle.min.js"></script>
<script src="{{ asset('js/plugins.js') }}"></script>
<script src="{{ asset('js/script.js') }}"></script>
<script>
// Cart stored in memory (session only)
var cart = [];

function updateCartDisplay() {
  var total = cart.reduce(function(sum, item) { return sum + item.price * item.quantity; }, 0);
  var count = cart.reduce(function(sum, item) { return sum + item.quantity; }, 0);

  var badge = document.getElementById('cart-count');
  if (badge) badge.textContent = count;

  var headerTotal = document.getElementById('cart-total-header');


















  
  if (headerTotal) headerTotal.textContent = '$' + total.toFixed(2);

  var offcanvasTotal = document.getElementById('cart-total-offcanvas');
  if (offcanvasTotal) offcanvasTotal.textContent = '$' + total.toFixed(2);

  var cartList = document.getElementById('cart-items-list');
  if (cartList) {
    cartList.innerHTML = '';
    cart.forEach(function(item) {
      var li = document.createElement('li');
      li.className = 'list-group-item';
      li.innerHTML = '<div class="d-flex justify-content-between align-items-start mb-2">' +
                     '<div><h6 class="my-0">' + item.name + '</h6><small class="text-body-secondary">$' + item.price.toFixed(2) + ' each</small></div>' +
                     '<button type="button" class="btn btn-sm btn-close" onclick="removeFromCart(' + item.id + ')"></button>' +
                     '</div>' +
                     '<div class="d-flex justify-content-between align-items-center">' +
                     '<div class="btn-group" role="group">' +
                     '<button type="button" class="btn btn-sm btn-outline-secondary" onclick="updateQuantity(' + item.id + ', -1)">-</button>' +
                     '<span class="btn btn-sm btn-light" disabled>' + item.quantity + '</span>' +
                     '<button type="button" class="btn btn-sm btn-outline-secondary" onclick="updateQuantity(' + item.id + ', 1)">+</button>' +
                     '</div>' +
                     '<span class="text-body-secondary fw-bold">$' + (item.price * item.quantity).toFixed(2) + '</span>' +
                     '</div>';
      cartList.appendChild(li);
    });
    var totalLi = document.createElement('li');
    totalLi.className = 'list-group-item d-flex justify-content-between';
    totalLi.innerHTML = '<span>Total (USD)</span><strong>$' + total.toFixed(2) + '</strong>';
    cartList.appendChild(totalLi);
  }
}

function removeFromCart(productId) {
  cart = cart.filter(function(item) { return item.id !== productId; });
  updateCartDisplay();
}

function updateQuantity(productId, change) {
  var item = cart.find(function(i) { return i.id === productId; });
  if (item) {
    item.quantity += change;
    if (item.quantity <= 0) {
      removeFromCart(productId);
    } else {
      updateCartDisplay();
    }
  }
}

function addToCart(productId, productName, productPrice) {
  var existing = cart.find(function(i) { return i.id === productId; });
  if (existing) {
    existing.quantity += 1;
  } else {
    cart.push({ id: productId, name: productName, price: productPrice, quantity: 1 });
  }
  updateCartDisplay();
  showNotification(productName + ' added to cart!');
}

function showNotification(message) {
  var notification = document.createElement('div');
  notification.className = 'alert alert-success position-fixed bottom-0 end-0 m-3';
  notification.style.zIndex = '9999';
  notification.innerHTML = '<small>' + message + '</small>';
  document.body.appendChild(notification);
  setTimeout(function() {
    notification.remove();
  }, 2500);
}

function openCheckoutModal() {
  if (cart.length === 0) {
    showNotification('Your cart is empty!');
    return;
  }
  
  var checkoutList = document.getElementById('checkout-items-list');
  checkoutList.innerHTML = '';
  
  var total = 0;
  cart.forEach(function(item) {
    var itemTotal = item.price * item.quantity;
    total += itemTotal;
    var li = document.createElement('li');
    li.className = 'list-group-item d-flex justify-content-between align-items-center';
    li.innerHTML = '<div><h6 class="mb-1">' + item.name + '</h6><small class="text-muted">$' + item.price.toFixed(2) + ' x ' + item.quantity + '</small></div><span class="fw-bold">$' + itemTotal.toFixed(2) + '</span>';
    checkoutList.appendChild(li);
  });
  
  var totalEl = document.getElementById('checkout-total');
  totalEl.textContent = '$' + total.toFixed(2);
  
  document.getElementById('checkoutModal').style.display = 'flex';
}

function closeCheckoutModal() {
  document.getElementById('checkoutModal').style.display = 'none';
}

function placeOrder() {
  if (cart.length === 0) {
    showNotification('Cart is empty!');
    return;
  }
  
  var total = cart.reduce(function(sum, item) { return sum + item.price * item.quantity; }, 0);
  alert('Order placed successfully!\n\nTotal: $' + total.toFixed(2) + '\n\nThank you for your purchase!');
  
  closeCheckoutModal();
  cart = [];
  updateCartDisplay();
}

function filterProducts() {
  var categoryVal = (document.getElementById('client-category-filter') || {}).value || '';
  var searchVal = (document.getElementById('product-filter-input') || document.getElementById('header-search-input') || {}).value || '';
  searchVal = searchVal.trim().toLowerCase();

  document.querySelectorAll('.product-card').forEach(function(card) {
    var name = card.getAttribute('data-product-name') || '';
    var cat  = card.getAttribute('data-category-name') || '';
    var matchCat    = !categoryVal || cat === categoryVal.toLowerCase();
    var matchSearch = !searchVal  || name.indexOf(searchVal) !== -1 || cat.indexOf(searchVal) !== -1;
    card.style.display = (matchCat && matchSearch) ? '' : 'none';
  });
}

document.addEventListener('DOMContentLoaded', function() {
  updateCartDisplay();

  // All filter inputs share the same filterProducts function
  ['client-category-filter', 'nav-category-filter', 'header-category-filter'].forEach(function(id) {
    var el = document.getElementById(id);
    if (el) {
      el.addEventListener('change', function() {
        // Sync all category dropdowns to same value
        ['client-category-filter', 'nav-category-filter', 'header-category-filter'].forEach(function(syncId) {
          var s = document.getElementById(syncId);
          if (s) s.value = el.value;
        });
        filterProducts();
      });
    }
  });

  ['product-filter-input', 'header-search-input'].forEach(function(id) {
    var el = document.getElementById(id);
    if (el) el.addEventListener('input', filterProducts);
  });

  // Offcanvas search button
  var offcanvasBtn = document.getElementById('offcanvas-search-btn');
  var offcanvasInput = document.getElementById('offcanvas-search-input');
  if (offcanvasBtn && offcanvasInput) {
    offcanvasBtn.addEventListener('click', function() {
      var headerInput = document.getElementById('header-search-input');
      if (headerInput) {
        headerInput.value = offcanvasInput.value;
        filterProducts();
      }
    });
  }
});
</script>



