    .modal-window {
        background: #fff;
        border-radius: 1rem;
        box-shadow: 0 25px 50px rgba(0,0,0,0.25);
        width: 100%;
        max-width: 600px;
        max-height: 90vh;
        overflow-y: auto;
        animation: slideUp 0.3s ease;
    }
    @keyframes slideUp {
        from { opacity: 0; transform: translateY(40px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .list-group-item {
        padding: 0.5rem 1rem !important;
    }
