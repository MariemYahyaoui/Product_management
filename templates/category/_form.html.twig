{{ form_start(form, { 'attr': { 'class': 'needs-validation', 'novalidate': 'novalidate' } }) }}
    <div class="mb-4">
        <label for="{{ form.categoryName.vars.id }}" class="form-label fw-semibold text-muted">Category Name</label>
        {{ form_widget(form.categoryName, { 'attr': { 'class': 'form-control form-control-lg rounded-3', 'placeholder': 'Enter category name', 'required': 'required' } }) }}
    </div>

    <div class="mb-4">
        <label for="{{ form.description.vars.id }}" class="form-label fw-semibold text-muted">Description</label>
        {{ form_widget(form.description, { 'attr': { 'class': 'form-control rounded-3', 'placeholder': 'Enter description (optional)', 'rows': 4 } }) }}
    </div>

    <div class="d-flex gap-3 justify-content-end mt-5 pt-3 border-top">
        <a href="{{ path('app_index') }}" class="btn btn-outline-secondary rounded-3 px-4">Cancel</a>
        <button class="btn btn-primary rounded-3 px-5">{{ button_label|default('Save') }}</button>
    </div>
{{ form_end(form) }}
